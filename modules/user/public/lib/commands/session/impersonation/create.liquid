{% liquid 
session original_user_id = params.actor_id
function object = 'modules/user/commands/session/create/build', id: params.target_id
function object = 'modules/user/commands/session/create/check', object: object
  if object.valid
    function user = 'modules/user/queries/user/load', id: object.id
    if user.id
      sign_in user_id: user.id
      assign params = '{}' | parse_json | hash_merge: user: user, hook_params: hook_params
      function results = 'modules/core/commands/hook/fire', hook: 'user_login', params: params, merge_to_object: true
      hash_assign user['hook_results'] = results
    endif
  endif
  assign event_object = null | hash_merge: actor_id: params.actor_id , target_id:params.target_id , type: params.type
  function _ = 'modules/core/commands/events/publish', type: 'user_logged_in_as_another_user', object: event_objects
  assign redirect_path = results.hook_results.redirect_to | default: params.redirect_to | default: '/'
  hash_assign user['redirect_path'] = redirect_path

  return object
     %}


