{% liquid 
session original_user_id = null
function object = 'modules/user/commands/session/create/build', id: params.user.id
function object = 'modules/user/commands/session/create/check', object: object
  if object.valid
    if params.user.id
      sign_in user_id: user.id
      assign params = '{}' | parse_json | hash_merge: user: user, hook_params: hook_params
      function results = 'modules/core/commands/hook/fire', hook: 'user_login', params: params, merge_to_object: true
      hash_assign user['hook_results'] = results
      assign event_object = null | hash_merge: login_as_id: params.actor_id , original_id: params.user.id
      function _ = 'modules/core/commands/events/publish', type: 'impersonation_ended', object: event_objects
    endif
  endif
 
  assign redirect_path = results.hook_results.redirect_to | default: params.redirect_to | default: '/'
  hash_assign user['redirect_path'] = redirect_path
  return user
     %}