---
slug: sessions/:user_id/relog
method: patch
---

{% liquid
unless context.session.original_user_id or context.session.original_user_id  != context.params.user_id
redirect_to "/"
endunless
function admin_user = 'modules/user/queries/user/find', id:context.session.original_user_id
include 'modules/user/helpers/can_do_or_unauthorized', do: 'users.logging_as', requester: admin_user
assign params =  null | hash_merge: actor_id: context.current_user.id , target_id: context.session.original_user_id , type: "relog"
function relog = 'modules/user/commands/session/impersonation/create', params: params

redirect_to relog.redirect_path
%}
