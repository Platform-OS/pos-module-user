---
slug: sessions/:user_id/relog
method: post
---

{% liquid

unless context.session.original_user_id or context.session.original_user_id  != context.params.user_id
redirect_to "/"
endunless
function admin_user = 'modules/user/queries/user/load', id: context.params.user_id
include 'modules/user/helpers/can_do_or_unauthorized', do: 'users.logging_as', requester: admin_user
assign params =  null | hash_merge: actor_id: context.current_user.id , user:admin_user
function relog = 'modules/user/commands/session/impersonation/destroy', params: params

redirect_to relog.redirect_path
%}
